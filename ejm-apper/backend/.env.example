# EJMapper environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env — it is in .gitignore.
#
# Keys that ARE required:
ANTHROPIC_API_KEY=          # Get at: https://console.anthropic.com

# EPA AQS (Air Quality System) — free, register at https://aqs.epa.gov/data/api/signup
AQS_EMAIL=
AQS_KEY=

# US Census Bureau API key — free + instant at https://api.census.gov/data/key_signup.html
# Used for the heat-vulnerability demographics (ACS). The Census API rejects
# keyless requests, so leaving this empty means that component serves
# clearly-labeled mock data until you add a key.
CENSUS_API_KEY=

# Keys that are NOT needed (these APIs are fully open):
# - EPA EJScreen       → no key
# - US Census Geocoder → no key
# - EPA ECHO           → no key
# - CDC PLACES         → no key
# - OpenStreetMap      → no key
# - NASA POWER         → no key (heat layer)
