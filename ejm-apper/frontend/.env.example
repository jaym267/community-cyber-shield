# Frontend environment variables (Vite).
# Copy to .env for local dev, and set these in the Vercel dashboard for production.
# NEVER commit .env — it is in .gitignore.

# Mapbox access token (publishable "pk." token).
# Get one at https://account.mapbox.com
VITE_MAPBOX_TOKEN=

# Base URL of the deployed backend API.
# Local dev: leave blank (defaults to http://127.0.0.1:8000).
# Production: set to your Render URL, e.g. https://ejmapper-api.onrender.com
VITE_API_BASE=
